# Supabase (Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx

# AdMob (선택) — 지정하지 않으면 개발 중에는 테스트 광고 단위 ID를 사용해요.
EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID=ca-app-pub-xxxxxxxx/xxxxxxxxxx

# 아래 값들은 클라이언트(.env)가 아니라 Supabase Edge Function 환경에 설정하세요.
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   (SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY는 Supabase가 자동으로 주입해요)
